---
import PageLayout from "@/layouts/Base";
---

<PageLayout meta={{ title: "Past Projects" }}>
	<div class="flex flex-col gap-8">
		<section>
			<h1 class="mb-6 text-2xl font-bold text-accent-2">Past Projects</h1>
		</section>

		<section aria-labelledby="inactive-heading">
			<h2 id="inactive-heading" class="mb-4 text-base font-semibold uppercase tracking-wider text-accent opacity-70">
				Inactive
			</h2>
			<div class="flex flex-col gap-3">
				<a
					href="https://podcasters.spotify.com/pod/show/zarchiwumit"
					target="_blank"
					rel="noopener noreferrer"
					class="group flex flex-col gap-1 rounded-lg border border-textColor/10 bg-bgColor p-4 transition-colors duration-200 motion-reduce:transition-none hover:border-link/40 hover:bg-link/5 focus-visible:ring-2 focus-visible:ring-link focus-visible:outline-none"
					aria-label="Z Archiwum IT podcast"
				>
					<div class="flex items-center gap-1.5">
						<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-60" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 2m0 3a3 3 0 0 1 3 -3h0a3 3 0 0 1 3 3v5a3 3 0 0 1 -3 3h0a3 3 0 0 1 -3 -3z"/>
							<path d="M5 10a7 7 0 0 0 14 0"/>
							<path d="M8 21l8 0"/>
							<path d="M12 17l0 4"/>
						</svg>
						<span class="text-xs font-semibold uppercase tracking-wider text-accent opacity-70">Podcast</span>
					</div>
					<p class="text-base font-semibold text-accent-2 transition-colors duration-200 motion-reduce:transition-none group-hover:text-link">Z&nbsp;Archiwum&nbsp;IT</p>
					<p class="text-xs leading-relaxed text-textColor opacity-60">
						Stories from the history of Polish IT.
					</p>
				</a>
			</div>
		</section>
	</div>
</PageLayout>
