---
import PageLayout from "@/layouts/Base";
import SocialList from "@/components/SocialList";
import michalczukmPhoto from "../assets/michalczukm-promo.png";
import { Image } from "astro:assets";
import { SOCIAL_LINKS } from "@/data/constants";

const DRAMA_CHANNEL_ID = "UCfpnY5NnBl-8L7SvICQPtKA";

interface YtVideo {
	id: string;
	title: string;
	thumbnail: string;
}

let recentVideos: YtVideo[] = [];
try {
	const rss = await fetch(
		`https://www.youtube.com/feeds/videos.xml?channel_id=${DRAMA_CHANNEL_ID}`
	).then((r) => r.text());

	const entries = [...rss.matchAll(/<entry>([\s\S]*?)<\/entry>/g)].slice(0, 3);
	recentVideos = entries.map((m) => {
		const block = m[1] ?? "";
		const id = (block.match(/<yt:videoId>([^<]+)<\/yt:videoId>/) ?? [])[1] ?? "";
		const title = (block.match(/<title>([^<]+)<\/title>/) ?? [])[1] ?? "";
		return {
			id,
			title,
			thumbnail: `https://img.youtube.com/vi/${id}/mqdefault.jpg`,
		};
	});
} catch {
	// silently skip thumbnails if fetch fails
}
---

<PageLayout meta={{ title: "Home" }}>
	<div class="flex h-full flex-col justify-between gap-3 py-1 sm:gap-5 sm:py-3">

		<!-- Hero section -->
		<section aria-labelledby="hero-heading" class="flex items-center gap-4 sm:gap-8">
			<div class="shrink-0">
				<Image
					class="h-16 w-16 rounded-xl object-cover sm:h-24 sm:w-24"
					src={michalczukmPhoto}
					alt="Michał Michalczuk"
					width={96}
					height={96}
					fetchpriority="high"
				/>
			</div>
			<div class="flex flex-col gap-1 sm:gap-2">
				<h1 id="hero-heading" class="text-balance text-xl font-bold leading-tight text-accent-2 sm:text-3xl">
					Full-Stack Engineer &amp;&nbsp;IT Trainer
				</h1>
				<p class="text-xs leading-relaxed text-textColor opacity-80 sm:text-sm">
					Senior Software Engineer at{" "}
					<a
						href="https://www.tektitconsulting.com/"
						target="_blank"
						rel="noopener noreferrer"
						class="cactus-link font-medium"
						title="Tektit Consulting"
					>Tektit</a>.
					Web, Node.js, TypeScript, AI.
				</p>
			</div>
		</section>

		<!-- Divider -->
		<hr class="border-dashed border-textColor opacity-20" />

		<!-- Cards grid — always 2x2 -->
		<section aria-label="Highlights" class="grid grid-cols-2 gap-3">
			<!-- DRAMA-devs -->
			<a
				href={SOCIAL_LINKS.youtube}
				target="_blank"
				rel="noopener noreferrer"
				class="group relative flex min-h-[7rem] overflow-hidden rounded-lg border border-textColor/10 bg-bgColor p-3 transition-colors duration-200 motion-reduce:transition-none hover:border-link/40 hover:bg-link/5 focus-visible:ring-2 focus-visible:ring-link focus-visible:outline-none sm:p-4"
				aria-label="DRAMA-devs YouTube channel"
			>
				<!-- text content -->
				<div class="relative z-10 flex flex-col gap-1 pr-2">
					<div class="flex items-center gap-1.5">
						<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-60" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
							<path stroke="none" d="M0 0h24v24H0z" fill="none"/>
							<path d="M2 8a4 4 0 0 1 4 -4h12a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-12a4 4 0 0 1 -4 -4v-8z"/>
							<path d="M10 9l5 3l-5 3z"/>
						</svg>
						<span class="text-[10px] font-semibold uppercase tracking-wider text-accent opacity-70 sm:text-xs">YouTube</span>
					</div>
					<p class="text-sm font-semibold text-accent-2 transition-colors duration-200 motion-reduce:transition-none group-hover:text-link sm:text-base">DRAMA-devs</p>
					<p class="hidden text-xs leading-relaxed text-textColor opacity-60 sm:block">
						Co-host. Web, architecture, drama — with JustJoin&nbsp;It.
					</p>
					<p class="text-[11px] leading-relaxed text-textColor opacity-60 sm:hidden">
						Co-host with JustJoin&nbsp;It.
					</p>
				</div>

				<!-- thumbnail stack -->
				{recentVideos.length > 0 && (
					<div class="pointer-events-none absolute inset-y-0 right-0 w-[55%]" aria-hidden="true">
						{recentVideos.slice(0, 3).map((video, i) => (
							<img
								src={video.thumbnail}
								alt=""
								width="320"
								height="180"
								loading="lazy"
								decoding="async"
								class="absolute w-[80%] rounded-md object-cover shadow-md"
								style={{
									top: `${6 + i * 14}%`,
									right: `${-2 + i * -8}%`,
									transform: `rotate(${4 - i * 5}deg)`,
									zIndex: 3 - i,
									opacity: 1 - i * 0.15,
								}}
							/>
						))}
					</div>
				)}
			</a>

			<!-- Talks -->
			<a
				href="/talks"
				class="group flex flex-col gap-1 rounded-lg border border-textColor/10 bg-bgColor p-3 transition-colors duration-200 motion-reduce:transition-none hover:border-link/40 hover:bg-link/5 focus-visible:ring-2 focus-visible:ring-link focus-visible:outline-none sm:p-4"
				aria-label="Selected conference talks"
			>
				<div class="flex items-center gap-1.5">
					<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-60" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<path d="M9 2m0 3a3 3 0 0 1 3 -3h0a3 3 0 0 1 3 3v5a3 3 0 0 1 -3 3h0a3 3 0 0 1 -3 -3z"/>
						<path d="M5 10a7 7 0 0 0 14 0"/>
						<path d="M8 21l8 0"/>
						<path d="M12 17l0 4"/>
					</svg>
					<span class="text-[10px] font-semibold uppercase tracking-wider text-accent opacity-70 sm:text-xs">Speaking</span>
				</div>
				<p class="text-sm font-semibold text-accent-2 transition-colors duration-200 motion-reduce:transition-none group-hover:text-link sm:text-base">Selected Talks</p>
				<p class="hidden text-xs leading-relaxed text-textColor opacity-60 sm:block">
					Conferences &amp; meetups on web, Node.js, and AI.
				</p>
				<p class="text-[11px] leading-relaxed text-textColor opacity-60 sm:hidden">
					Conferences &amp; meetups.
				</p>
			</a>

			<!-- Meet.js Gdańsk -->
			<a
				href="https://www.meetup.com/gdansk-typescript/"
				target="_blank"
				rel="noopener noreferrer"
				class="group flex flex-col gap-1 rounded-lg border border-textColor/10 bg-bgColor p-3 transition-colors duration-200 motion-reduce:transition-none hover:border-link/40 hover:bg-link/5 focus-visible:ring-2 focus-visible:ring-link focus-visible:outline-none sm:p-4"
				aria-label="Meet.js Gdańsk meetup group"
			>
				<div class="flex items-center gap-1.5">
					<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-60" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<path d="M5.455 10.82c.935 -2.163 3.045 -3.82 5.545 -3.82c2.104 0 2.844 1.915 2 4l-2 6"/>
						<path d="M6.981 7l-3.981 9.914"/>
						<path d="M13 11c.937 -2.16 3.071 -3.802 5.42 -3.972c2.104 0 3.128 1.706 2.284 3.792l-2.454 6.094c-.853 1.676 .75 2.586 2.75 2.086"/>
					</svg>
					<span class="text-[10px] font-semibold uppercase tracking-wider text-accent opacity-70 sm:text-xs">Meetup</span>
				</div>
				<p class="text-sm font-semibold text-accent-2 transition-colors duration-200 motion-reduce:transition-none group-hover:text-link sm:text-base">Meet.js Gdańsk</p>
				<p class="hidden text-xs leading-relaxed text-textColor opacity-60 sm:block">
					Co-organizer. TypeScript &amp; web dev meetup.
				</p>
				<p class="text-[11px] leading-relaxed text-textColor opacity-60 sm:hidden">
					Co-organizer.
				</p>
			</a>

			<!-- Gabinet Wieczorynka -->
			<a
				href="https://gabinet-wieczorynka.pl"
				target="_blank"
				rel="noopener noreferrer"
				class="group flex flex-col gap-1 rounded-lg border border-textColor/10 bg-bgColor p-3 transition-colors duration-200 motion-reduce:transition-none hover:border-link/40 hover:bg-link/5 focus-visible:ring-2 focus-visible:ring-link focus-visible:outline-none sm:p-4"
				aria-label="Gabinet Lekarski Wieczorynka"
			>
				<div class="flex items-center gap-1.5">
					<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-60" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<path stroke="none" d="M0 0h24v24H0z" fill="none"/>
						<path d="M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0"/>
						<path d="M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0"/>
						<path d="M3 6l0 13"/>
						<path d="M12 6l0 13"/>
						<path d="M21 6l0 13"/>
					</svg>
					<span class="text-[10px] font-semibold uppercase tracking-wider text-accent opacity-70 sm:text-xs">Project</span>
				</div>
				<p class="text-sm font-semibold text-accent-2 transition-colors duration-200 motion-reduce:transition-none group-hover:text-link sm:text-base">Gabinet Wieczorynka</p>
				<p class="hidden text-xs leading-relaxed text-textColor opacity-60 sm:block">
					Our medical practice.
				</p>
				<p class="text-[11px] leading-relaxed text-textColor opacity-60 sm:hidden">
					Our medical practice.
				</p>
			</a>
		</section>

		<!-- Divider -->
		<hr class="border-dashed border-textColor opacity-20" />

		<!-- Social links -->
		<section aria-label="Social links">
			<SocialList />
		</section>
	</div>
</PageLayout>
